<Window x:Class="Quickbite_AdminPanel.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickBite Admin - Bejelentkezés" 
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- QuickBite színvilág - természetes, földi tónusok -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3C3D37"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#697565"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5EDE0"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="TextColor" Color="#181C14"/>
        <SolidColorBrush x:Key="BorderColor" Color="#8B7A6B"/>
        
        <!-- Button stílus -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox stílus -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox stílus -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <!-- Login kártya -->
        <Border Width="420" Height="500" 
                Background="{StaticResource CardBackground}"
                CornerRadius="16"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.1" 
                                BlurRadius="30" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="40">
                <!-- Logo / Title -->
                <TextBlock Text="🍕 QuickBite" 
                          FontSize="32" 
                          FontWeight="Bold"
                          Foreground="{StaticResource PrimaryColor}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,8"/>
                
                <TextBlock Text="Admin Panel" 
                          FontSize="20" 
                          FontWeight="SemiBold"
                          Foreground="{StaticResource TextColor}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,35"/>

                <!-- Email -->
                <TextBlock Text="Email cím" 
                          FontSize="13" 
                          FontWeight="Medium"
                          Foreground="{StaticResource TextColor}"
                          Margin="0,0,0,6"/>
                
                <TextBox x:Name="EmailTextBox" 
                        Style="{StaticResource ModernTextBox}"
                        Margin="0,0,0,16"/>

                <!-- Jelszó -->
                <TextBlock Text="Jelszó" 
                          FontSize="13" 
                          FontWeight="Medium"
                          Foreground="{StaticResource TextColor}"
                          Margin="0,0,0,6"/>
                
                <PasswordBox x:Name="PasswordBox" 
                            Style="{StaticResource ModernPasswordBox}"
                            Margin="0,0,0,25"/>

                <!-- Error message -->
                <TextBlock x:Name="ErrorMessage" 
                          Text="" 
                          Foreground="Red"
                          FontSize="11"
                          TextWrapping="Wrap"
                          Margin="0,0,0,12"
                          Visibility="Collapsed"/>

                <!-- Login gomb -->
                <Button x:Name="LoginButton" 
                       Content="Bejelentkezés" 
                       Style="{StaticResource PrimaryButton}"
                       Click="LoginButton_Click"
                       Margin="0,0,0,15"/>

                <!-- Loading indicator -->
                <TextBlock x:Name="LoadingMessage" 
                          Text="Bejelentkezés..." 
                          Foreground="{StaticResource PrimaryColor}"
                          FontSize="13"
                          HorizontalAlignment="Center"
                          Visibility="Collapsed"/>

                <!-- Close button -->
                <Button Content="Kilépés" 
                       Background="Transparent"
                       Foreground="#718096"
                       BorderThickness="0"
                       FontSize="12"
                       Cursor="Hand"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
