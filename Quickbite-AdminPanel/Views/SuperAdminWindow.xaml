<Window x:Class="Quickbite_AdminPanel.Views.SuperAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Quickbite_AdminPanel.Converters"
        Title="QuickBite - Super Admin Panel" 
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <!-- QuickBite színvilág - természetes, földi tónusok -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3C3D37"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#697565"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5EDE0"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>
        <SolidColorBrush x:Key="TextColor" Color="#181C14"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#697565"/>
        <SolidColorBrush x:Key="BorderColor" Color="#8B7A6B"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#697565"/>
        <SolidColorBrush x:Key="DangerColor" Color="#C44536"/>
        
        <!-- Card stílus -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                    BlurRadius="20" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button stílusok -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerColor}"/>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <StackPanel>
                            <TabPanel x:Name="HeaderPanel"
                                     IsItemsHost="True"
                                     Panel.ZIndex="1"
                                     Margin="0"
                                     Background="Transparent"/>
                            <Border x:Name="ContentPanel"
                                   Background="{StaticResource CardBackground}"
                                   CornerRadius="0,12,12,12"
                                   Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                    BlurRadius="20" ShadowDepth="0"/>
                                </Border.Effect>
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                ContentSource="SelectedContent" />
                            </Border>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="BorderTab"
                               BorderThickness="1,1,1,0" 
                               BorderBrush="{StaticResource BorderColor}"
                               Background="{StaticResource CardBackground}"
                               CornerRadius="12,12,0,0"
                               Padding="20,12"
                               Margin="0,0,5,0">
                            <ContentPresenter x:Name="HeaderPresenter"
                                            ContentSource="Header" 
                                            TextBlock.FontSize="14"
                                            TextBlock.FontWeight="SemiBold"
                                            TextBlock.Foreground="{StaticResource TextSecondary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BorderTab" Property="Background" Value="{StaticResource CardBackground}"/>
                                <Setter TargetName="HeaderPresenter" Property="TextBlock.Foreground" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackground}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" 
                                BlurRadius="15" ShadowDepth="2"/>
            </Border.Effect>
            
            <Grid Margin="30,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🍕 QuickBite" 
                             FontSize="20" 
                             FontWeight="Bold"
                             Foreground="{StaticResource PrimaryColor}"
                             VerticalAlignment="Center"/>
                    
                    <TextBlock Text="Super Admin Panel" 
                             FontSize="15" 
                             Foreground="{StaticResource TextSecondary}"
                             VerticalAlignment="Center"
                             Margin="15,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" 
                             Text="Admin" 
                             FontSize="13" 
                             FontWeight="Medium"
                             Foreground="{StaticResource TextColor}"
                             VerticalAlignment="Center"
                             Margin="0,0,15,0"/>
                    
                    <Button Content="Kijelentkezés" 
                           Background="#ECDFCC"
                           Foreground="{StaticResource TextColor}"
                           FontSize="12"
                           Padding="14,7"
                           BorderThickness="0"
                           Cursor="Hand"
                           Click="LogoutButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                       CornerRadius="6"
                                       Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,25">
                
                <!-- Dashboard Stats -->
                <TextBlock Text="Dashboard" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="{StaticResource TextColor}"
                          Margin="0,0,0,18"/>

                <Grid Margin="0,0,0,35">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Éttermek -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="🏪 Éttermek" 
                                     FontSize="13" 
                                     Foreground="{StaticResource TextSecondary}"
                                     Margin="0,0,0,6"/>
                            <TextBlock x:Name="TotalRestaurantsText" 
                                     Text="0" 
                                     FontSize="28" 
                                     FontWeight="Bold"
                                     Foreground="{StaticResource TextColor}"/>
                        </StackPanel>
                    </Border>

                    <!-- Adminok -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="👤 Adminok" 
                                     FontSize="13" 
                                     Foreground="{StaticResource TextSecondary}"
                                     Margin="0,0,0,6"/>
                            <TextBlock x:Name="TotalAdminsText" 
                                     Text="0" 
                                     FontSize="28" 
                                     FontWeight="Bold"
                                     Foreground="{StaticResource TextColor}"/>
                        </StackPanel>
                    </Border>

                    <!-- Rendelések -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="📦 Rendelések" 
                                     FontSize="13" 
                                     Foreground="{StaticResource TextSecondary}"
                                     Margin="0,0,0,6"/>
                            <TextBlock x:Name="TotalOrdersText" 
                                     Text="0" 
                                     FontSize="28" 
                                     FontWeight="Bold"
                                     Foreground="{StaticResource TextColor}"/>
                        </StackPanel>
                    </Border>

                    <!-- Bevétel -->
                    <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="💰 Összes bevétel" 
                                     FontSize="13" 
                                     Foreground="{StaticResource TextSecondary}"
                                     Margin="0,0,0,6"/>
                            <TextBlock x:Name="TotalRevenueText" 
                                     Text="0 Ft" 
                                     FontSize="28" 
                                     FontWeight="Bold"
                                     Foreground="{StaticResource SuccessColor}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Management Tabs -->
                <TabControl Margin="0,0,0,0" Background="Transparent">
                    <!-- Admin Kezelés Tab -->
                    <TabItem Header="Admin Kezelés" IsSelected="True">
                        <StackPanel Margin="0,15,0,0">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Adminok" 
                                          FontSize="20" 
                                          FontWeight="Bold"
                                          Foreground="{StaticResource TextColor}"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="1" 
                                       Content="➕ Új Admin Hozzáadása" 
                                       Style="{StaticResource PrimaryButton}"
                                       Click="AddAdminButton_Click"/>
                            </Grid>

                            <!-- Admins List -->
                            <Border Background="{StaticResource CardBackground}"
                                   CornerRadius="12"
                                   Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                    BlurRadius="20" ShadowDepth="0"/>
                                </Border.Effect>

                                <DataGrid x:Name="AdminsDataGrid" 
                                         AutoGenerateColumns="False"
                                         IsReadOnly="True"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="None"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         RowHeight="60"
                                         CanUserResizeRows="False"
                                         FontSize="13">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="180"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                                        <DataGridTextColumn Header="Szerepkör" Binding="{Binding Role}" Width="130"/>
                                        <DataGridTemplateColumn Header="Éttermek" Width="200">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ItemsControl ItemsSource="{Binding Restaurants}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" 
                                                                          FontSize="11"
                                                                          Foreground="#697565"
                                                                          Margin="0,1"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Létrehozva" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                        <DataGridTemplateColumn Header="Műveletek" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="🗑️ Törlés" 
                                                           Style="{StaticResource DangerButton}"
                                                           Padding="12,6"
                                                           FontSize="12"
                                                           Click="DeleteAdminButton_Click"
                                                           Tag="{Binding Id}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- Étterem Kezelés Tab -->
                    <TabItem Header="Étterem Kezelés">
                        <StackPanel Margin="0,15,0,0">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Éttermek" 
                                          FontSize="20" 
                                          FontWeight="Bold"
                                          Foreground="{StaticResource TextColor}"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="1" 
                                       Content="➕ Új Étterem" 
                                       Style="{StaticResource PrimaryButton}"
                                       Click="AddRestaurantButton_Click"/>
                            </Grid>

                            <!-- Restaurants List -->
                            <Border Background="{StaticResource CardBackground}"
                                   CornerRadius="12"
                                   Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.08" 
                                                    BlurRadius="20" ShadowDepth="0"/>
                                </Border.Effect>

                                <DataGrid x:Name="RestaurantsDataGrid" 
                                         AutoGenerateColumns="False"
                                         IsReadOnly="True"
                                         HeadersVisibility="Column"
                                         GridLinesVisibility="None"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         RowHeight="55"
                                         CanUserResizeRows="False"
                                         FontSize="13">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Étterem Név" Binding="{Binding Name}" Width="180"/>
                                        <!-- Email removed: restaurant entity doesn't include email -->
                                        <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>
                                        <DataGridTextColumn Header="Admin" Binding="{Binding AdminName}" Width="150"/>
                                        <!-- Status column removed as it's not needed -->
                                        <DataGridTextColumn Header="Létrehozva" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                                        <DataGridTemplateColumn Header="Műveletek" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="🔄 Státusz" 
                                                               Style="{StaticResource PrimaryButton}"
                                                               Padding="10,6"
                                                               FontSize="11"
                                                               Click="ToggleRestaurantStatusButton_Click"
                                                               Tag="{Binding Id}"
                                                               Margin="0,0,5,0"/>
                                                        <Button Content="🗑️ Törlés" 
                                                               Style="{StaticResource DangerButton}"
                                                               Padding="10,6"
                                                               FontSize="11"
                                                               Click="DeleteRestaurantButton_Click"
                                                               Tag="{Binding Id}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </TabItem>
                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
